# -----------------------------
# Todo-API Environment Template
# -----------------------------
# Copy this file to `.env` and fill in real values.
#
# IMPORTANT:
# - Never commit `.env`
# - These values are intentionally safe placeholders

# App
NODE_ENV=development
PORT=3000

# Auth
JWT_PRIVATE_KEY=replace_me_with_a_long_random_secret

# Postgres (Prisma expects DATABASE_URL)
# Local Docker Compose example:
# - user:     DB_USER
# - password: DB_PASSWORD
# - db:       DB_NAME
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=ticketing

# Prisma connection string used by the API
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ticketing?schema=public

# Integration-test connection string (same server, different DB)
DATABASE_URL_TEST=postgresql://postgres:postgres@localhost:5432/ticketing_test?schema=public

# MinIO (S3-compatible)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET_NAME=ticketing-attachments
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

